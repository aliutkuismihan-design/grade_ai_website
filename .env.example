# Copy to `.env.local` for local dev. On Railway, set these in the dashboard.

# Port the Next.js server listens on. Railway injects its own PORT at runtime;
# `next start` respects the PORT env var automatically.
PORT=3000

# Public base URL of the deployed site (used for metadata / canonical URLs).
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# Copy to `.env.local` for local dev. On Railway, set these in the dashboard.

# Port the Next.js server listens on. Railway injects its own PORT at runtime;
# `next start` respects the PORT env var automatically.
PORT=3000

# Public base URL of the deployed site (used for metadata / canonical URLs).
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# ── Google AdSense (opsiyonel) ──
# https://www.google.com/adsense → site ekle → reklam birimleri oluştur
# Publisher ID: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Her reklam birimi için farklı slot ID:
NEXT_PUBLIC_ADSENSE_LEADERBOARD=1234567890
NEXT_PUBLIC_ADSENSE_INLINE=1234567891
NEXT_PUBLIC_ADSENSE_BOX=1234567892
